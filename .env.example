# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/faceless_platform
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=faceless_platform
DATABASE_USER=username
DATABASE_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Services
OPENAI_API_KEY=your-openai-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=your-default-voice-id

# AWS/Cloud Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
CLOUDFRONT_DISTRIBUTION_ID=your-cloudfront-id

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
SESSION_SECRET=your-session-secret-key
ENCRYPTION_KEY=your-32-character-encryption-key

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# Email Services
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
FROM_EMAIL=noreply@facelessplatform.com

# Payment Processing
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Analytics & Monitoring
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
SENTRY_DSN=your-sentry-dsn-url
LOG_LEVEL=info

# Application Settings
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Content Processing
MAX_FILE_SIZE=100MB
MAX_VIDEO_DURATION=600
TEMP_UPLOAD_DIR=./uploads/temp
PROCESSED_CONTENT_DIR=./uploads/processed

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100
API_RATE_LIMIT=1000

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_MONETIZATION=true
ENABLE_AI_FEATURES=true
ENABLE_CONTENT_MODERATION=true

# Development Only
DEBUG=true
ENABLE_CORS=true
LOG_SQL_QUERIES=false
